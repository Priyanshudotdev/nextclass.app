# ============================================
# NextClass Primary Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# Server Configuration
# ============================================
PORT=8080
NODE_ENV=development
# Options: development, production, test

# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://username:password@localhost:5432/nextclass"
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ============================================
# Session & Authentication
# ============================================
SESSION_SECRET="your-super-secret-session-key-min-32-chars"
SESSION_EXPIRY_DAYS=7
# Session cookie settings
COOKIE_SECURE=false
# Set to true in production (requires HTTPS)
COOKIE_SAME_SITE=Strict
# Options: Strict, Lax, None

# ============================================
# Password Hashing
# ============================================
BCRYPT_SALT_ROUNDS=10
# Higher = more secure but slower (10-12 recommended)

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:3000
# Frontend URL for CORS. Use comma-separated for multiple origins
# Example: http://localhost:3000,https://app.nextclass.com
CORS_CREDENTIALS=true

# ============================================
# File Upload (UploadThing)
# ============================================
UPLOADTHING_TOKEN=your-uploadthing-token
# Get your token from https://uploadthing.com/dashboard

# Max file sizes (in MB)
MAX_IMAGE_SIZE=4
MAX_DOCUMENT_SIZE=16
MAX_VIDEO_SIZE=64

# ============================================
# Rate Limiting (Optional)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
# Time window in milliseconds (15 minutes = 900000)
RATE_LIMIT_MAX_REQUESTS=100
# Max requests per window per IP

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
# Options: error, warn, info, debug

# ============================================
# API Configuration
# ============================================
API_PREFIX=/api
API_VERSION=v1

# ============================================
# Pagination Defaults
# ============================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ============================================
# Frontend URLs (for redirects/emails)
# ============================================
FRONTEND_URL=http://localhost:3000
# Used for password reset links, email verification, etc.

# ============================================
# Email Configuration (Future)
# ============================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@nextclass.com

# ============================================
# Push Notifications (Future)
# ============================================
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=your-private-key
# FIREBASE_CLIENT_EMAIL=your-client-email

# ============================================
# Redis (Future - for caching/sessions)
# ============================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password
